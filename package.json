{
  "name": "website-schedler-co",
  "description": "Curriculum vitae (CV) | Alexander Schedler: Internet application engineering, development and management.",
  "version": "8.0.0",
  "type": "module",
  "license": "CC-BY-NC-ND",
  "repository": {
    "type": "git",
    "url": "https://github.com/kulturpessimist/schedler.co.git"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": "1.3.6"
  },
  "scripts": {
    "dev": "bun ./src/scripts/dev.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome lint .",
    "check:fix": "biome lint --write .",
    "clean:deps": "rm -rf node_modules",
    "clean:build": "rm -rf dist",
    "build:rev": "bun ./src/scripts/rev.js",
    "build:pages": "bun ./src/scripts/build-pages.js",
    "build:bundle": "bun build ./src/index.html --outdir dist --minify",
    "build:public": "bun ./src/scripts/build-public.js",
    "build": "bun run clean:build && bun run build:rev -- ./src/version.json && bun run build:pages && bun run build:bundle && bun run build:public",
    "preview": "bun ./src/scripts/preview.js",
    "surge": "bun run build && bunx surge --domain schedler-co-7.surge.sh dist/",
    "typecheck": "bunx tsc -p tsconfig.json"
  },
  "dependencies": {
    "navigo": "^8.11.1",
    "petite-vue": "^0.4.1",
    "rough-notation": "0.5.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@biomejs/biome": "^2.4.7",
    "asciify-image": "^0.1.10"
  }
}
